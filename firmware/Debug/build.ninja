build azrael_freeRTOS.elf: C_EXECUTABLE_LINKER__azrael_freeRTOS_Debug CMakeFiles/azrael_freeRTOS.dir/Startup/startup_stm32f103c8tx.s.obj CMakeFiles/azrael_freeRTOS.dir/Sources/main.c.obj CMakeFiles/azrael_freeRTOS.dir/Sources/syscalls.c.obj CMakeFiles/azrael_freeRTOS.dir/Sources/sysmem.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/tasks.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/queue.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/list.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/event_groups.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/stream_buffer.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/timers.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/portable/MemMang/heap_4.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/FreeRTOS/portable/GCC/ARM_CM3/port.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/ST7735/st7735/st7735.c.obj CMakeFiles/azrael_freeRTOS.dir/Drivers/ST7735/st7735/fonts.c.obj CMakeFiles/azrael_freeRTOS.dir/Sources/gpio.c.obj CMakeFiles/azrael_freeRTOS.dir/Sources/spi.c.obj CMakeFiles/azrael_freeRTOS.dir/Sources/display.c.obj
  CONFIG = Debug
  FLAGS = -mcpu=Cortex-M3 -std=gnu11   --specs=nano.specs -mthumb -Wall  -g
  LINK_FLAGS = -T../STM32F103C8TX_FLASH.ld --specs=nosys.specs -Wl,-Map=azrael_freeRTOS.map -Wl,--gc-sections -static -Wl,--start-group -lc -lm -Wl,--end-group
  OBJECT_DIR = CMakeFiles/azrael_freeRTOS.dir
  POST_BUILD = cd /home/hillary/Documents/embedded_projs/azrael_freertos/Debug && arm-none-eabi-size /home/hillary/Documents/embedded_projs/azrael_freertos/Debug/azrael_freeRTOS.elf
  PRE_LINK = :
  TARGET_FILE = azrael_freeRTOS.elf
  TARGET_PDB = azrael_freeRTOS.elf.dbg


